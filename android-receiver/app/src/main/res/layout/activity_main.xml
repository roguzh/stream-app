<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/videoRenderer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Waiting / connecting / disconnected overlay -->
    <LinearLayout
        android:id="@+id/statusOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/black">

        <View
            android:id="@+id/pulseDot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/dot_green" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/waiting_for_stream"
            android:textColor="@color/text_primary"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/serverUrlText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/changeServerButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/change_server" />
    </LinearLayout>

    <!-- First-run / manual server entry -->
    <LinearLayout
        android:id="@+id/serverEntryOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/overlay_scrim"
        android:visibility="gone"
        android:padding="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/server_address_hint"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/serverAddressInput"
            android:layout_width="420dp"
            android:layout_height="wrap_content"
            android:hint="@string/server_address_hint"
            android:inputType="textUri"
            android:textColor="@color/text_primary"
            android:textColorHint="#888888"
            android:singleLine="true"
            android:imeOptions="actionDone" />

        <Button
            android:id="@+id/connectButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/connect" />
    </LinearLayout>

    <!-- Stats overlay, toggled via remote -->
    <TextView
        android:id="@+id/statsText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="24dp"
        android:background="@drawable/stats_bg"
        android:fontFamily="monospace"
        android:padding="12dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:visibility="gone" />

</FrameLayout>
